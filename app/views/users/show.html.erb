<div style="max-width: 600px; margin: 40px auto; padding: 30px; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <h2 style="margin-top: 0;"><%= @user.name %></h2>
  
  <div style="background: #f9f9f9; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
    <p style="margin: 0 0 10px 0;"><strong>Role:</strong> <%= role_name(@user.role) %></p>
    <p style="margin: 0 0 10px 0;"><strong>Balance:</strong> € <%= number_with_precision(@user.balance, precision: 2) %></p>
    <p style="margin: 0;"><strong>Income:</strong> € <%= number_with_precision(@user.income, precision: 2) %></p>
  </div>

  <div style="display: flex; gap: 10px;">
    <% if current_user.admin? || current_user.id == @user.id %>
      <%= link_to "Edit", edit_user_path(@user), class: "btn btn-primary", style: "background: #ffa500; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; cursor: pointer;" %>
    <% end %>
    
    <% if current_user.admin? %>
      <%= link_to "Delete", user_path(@user), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger", style: "background: #ff0000; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; cursor: pointer;" %>
    <% end %>
    
    <%= link_to "Back", users_path, class: "btn btn-secondary", style: "background: #666; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; cursor: pointer;" %>
  </div>
</div>
