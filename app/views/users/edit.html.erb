<div style="max-width: 600px; margin: 40px auto; padding: 30px; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <h2 style="margin-top: 0;">Edit User</h2>

  <% if @user.errors.any? %>
    <div style="background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 6px; padding: 15px; margin-bottom: 20px;">
      <h4 style="margin-top: 0;"><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h4>
      <ul style="margin: 0; padding-left: 20px;">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with(model: @user, local: true) do |form| %>
    <div style="margin-bottom: 20px;">
      <%= form.label :name, style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
      <%= form.text_field :name, style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box;" %>
    </div>

    <div style="margin-bottom: 20px;">
      <%= form.label :password, "Password (leave blank to keep current)", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
      <%= form.password_field :password, style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box;" %>
    </div>

    <div style="margin-bottom: 20px;">
    
      <%= form.label :balance, style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
      <%= form.number_field :balance, step: 0.01, style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box;" %>
    </div>

    <div style="margin-bottom: 20px;">
      <%= form.label :income, style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
      <%= form.number_field :income, step: 0.01, style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box;" %>
    </div>

    <% if current_user.admin? %>
      <div style="margin-bottom: 20px;">
        <%= form.label :role, style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
        <%= form.select :role, { 'Admin' => 'admin', 'User' => 'user', 'Viewer' => 'viewer' }, {}, style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box;" %>
      </div>
    <% end %>

    <div style="margin-bottom: 20px;">
      <%= form.label :income_day, "Income Day (1-28)", style: "display: block, margin-bottom: 8px; font-weight: bold;" %>
      <%= form.number_field :income_day, in: 1..28, placeholder: "e.g. 25",
      style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box;" %>
      <small style="color: #666;">Day of the month, when you get your income.</small>
    </div>
    
    <%= form.submit "Update User", style: "width: 100%; padding: 12px; background: #ffa500; color: white; border: none; border-radius: 6px; font-size: 16px; font-weight: bold; cursor: pointer;" %>
  <% end %>

  <%= link_to "Back", user_path(@user), style: "color: #0066cc; text-decoration: none; margin-top: 20px; display: inline-block;" %>
</div>
