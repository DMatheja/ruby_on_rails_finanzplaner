<style>
  .login-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    border-bottom: 2px solid #444;
  }
  
  .tab-button {
    padding: 12px 24px;
    background: #2a2a2a;
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 16px;
    border-bottom: 3px solid transparent;
    transition: all 0.3s;
  }
  
  .tab-button.active {
    border-bottom-color: #00ff00;
    color: #00ff00;
  }
  
  .tab-button:hover {
    background: #333;
  }
  
  .tab-content {
    display: none;
  }
  
  .tab-content.active {
    display: block;
  }
  
  .security-panel {
    background: #1a1a1a;
    border: 2px solid #00aa00;
    border-radius: 8px;
    padding: 25px;
    color: #00ff00;
    font-family: 'Courier New', monospace;
    box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
  }
  
  .dictionary-list {
    background: #0a0a0a;
    border: 1px solid #00aa00;
    border-radius: 4px;
    padding: 15px;
    max-height: 200px;
    overflow-y: auto;
    margin: 15px 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  
  .dict-word {
    background: #1a1a1a;
    border: 1px solid #00aa00;
    padding: 8px;
    border-radius: 3px;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
    font-size: 12px;
  }
  
  .dict-word:hover {
    background: #00aa00;
    color: #000;
    box-shadow: 0 0 10px #00ff00;
  }
  
  .attack-result {
    margin-top: 20px;
    padding: 15px;
    border-radius: 4px;
    font-weight: bold;
    text-align: center;
  }
  
  .attack-success {
    background: rgba(0, 255, 0, 0.2);
    color: #00ff00;
    border: 2px solid #00ff00;
  }
  
  .attack-failure {
    background: rgba(255, 0, 0, 0.2);
    color: #ff4444;
    border: 2px solid #ff4444;
  }
  
  .control-panel {
    background: #0a0a0a;
    border: 1px solid #444;
    padding: 15px;
    border-radius: 4px;
    margin-bottom: 20px;
  }
  
  .control-label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  
  .toggle-switch {
    width: 50px;
    height: 28px;
    background: #ff0000;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    position: relative;
    transition: all 0.3s;
  }
  
  .toggle-switch.enabled {
    background: #00ff00;
  }
  
  .toggle-switch::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 24px;
    background: white;
    border-radius: 50%;
    top: 2px;
    left: 2px;
    transition: all 0.3s;
  }
  
  .toggle-switch.enabled::after {
    left: 24px;
  }
</style>

<div style="display: flex; min-height: 100vh; background: #1a1a1a; color: #fff; font-family: sans-serif;">
  <!-- Login Section -->
  <div style="flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px;">
    <div style="max-width: 500px; width: 100%; background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.2);">
      <h1 style="text-align: center; margin-bottom: 40px; color: #333;">Finanzplaner</h1>
      
      <% if @users.any? %>
        <form method="post" action="<%= sessions_path %>" style="margin-bottom: 30px;">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          
          <div style="margin-bottom: 20px;">
            <label for="user_name" style="display: block; margin-bottom: 8px; font-weight: bold; color: #333;">Username:</label>
            <input type="text" name="user_name" id="user_name" placeholder="Enter user name" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box;" required>
          </div>

          <div style="margin-bottom: 20px;">
            <label for="password" style="display: block; margin-bottom: 8px; font-weight: bold; color: #333;">Password:</label>
            <input type="password" name="password" id="password" placeholder="Enter password" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box;" required>
          </div>
          
          <button type="submit" style="width: 100%; padding: 12px; background: #0066cc; color: white; border: none; border-radius: 6px; font-size: 16px; font-weight: bold; cursor: pointer;">
            Login
          </button>
        </form>
        
        <p style="text-align: center; color: #666; margin-bottom: 20px;">OR</p>
        
        <button id="toggle-security" onclick="toggleSecurityPanel()" style="width: 100%; padding: 12px; background: #333; color: #0f0; border: 2px solid #0f0; border-radius: 6px; font-size: 14px; font-weight: bold; cursor: pointer; font-family: 'Courier New', monospace;">
          ▼ SECURITY PANEL (Educational)
        </button>
      <% else %>
        <p style="text-align: center; color: #999;">No users available. Please seed the database first.</p>
      <% end %>
    </div>
  </div>

  <!-- Security Panel Section -->
  <div id="security-section" style="flex: 1; display: none; align-items: center; justify-content: center; padding: 40px; background: #0f0f0f;">
    <div style="max-width: 500px; width: 100%;">
      <div class="security-panel">
        <h2 style="margin-top: 0; text-align: center; text-shadow: 0 0 10px #00ff00;">
          ⚠️ SECURITY SIMULATOR ⚠️
        </h2>
        
        <div class="control-panel">
          <p style="color: #666; font-size: 12px; margin: 0 0 15px 0;">Rate Limiting Control:</p>
          <div class="control-label">
            <span>Rate Limiting: </span>
            <button id="rate-limit-toggle" class="toggle-switch enabled" onclick="toggleRateLimiting()"></button>
            <span id="rate-limit-status">ON (3 tries)</span>
          </div>
          <p style="color: #888; font-size: 11px; margin: 0;">Simulation: Disable to bypass attempt limits</p>
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 10px; color: #00ff00;">TARGET USER:</label>
          <select id="attack-user" style="width: 100%; padding: 10px; background: #0a0a0a; color: #00ff00; border: 1px solid #00aa00; border-radius: 4px; font-family: monospace;">
            <option value="">-- Select target --</option>
            <% @users.each do |user| %>
              <option value="<%= user.id %>"><%= user.name %></option>
            <% end %>
          </select>
        </div>

        <div style="margin-bottom: 20px;">
          <p style="color: #00ff00; margin: 0 0 10px 0;">DICTIONARY WORDS:</p>
          <div class="dictionary-list" id="dict-list">
            <% @dictionary_words.each_with_index do |word, idx| %>
              <div class="dict-word" onclick="attackWord('<%= word %>')" title="<%= word %> (word <%= idx + 1 %>)">
                <%= word %>
              </div>
            <% end %>
          </div>
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 8px; color: #00ff00;">MANUAL INPUT:</label>
          <input type="text" id="manual-password" placeholder="Or type manually..." style="width: 100%; padding: 10px; background: #0a0a0a; color: #00ff00; border: 1px solid #00aa00; border-radius: 4px; font-family: monospace;">
        </div>

        <div style="display: flex; gap: 10px;">
          <button onclick="attackWord(document.getElementById('manual-password').value)" style="flex: 1; padding: 10px; background: #aa0000; color: #fff; border: 1px solid #ff0000; border-radius: 4px; cursor: pointer; font-weight: bold;">
            ATTEMPT
          </button>
          <button onclick="toggleSecurityPanel()" style="flex: 1; padding: 10px; background: #333; color: #fff; border: 1px solid #666; border-radius: 4px; cursor: pointer;">
            CLOSE
          </button>
        </div>

        <div id="attack-result"></div>
        <div id="attack-log" style="background: #0a0a0a; border: 1px solid #444; border-radius: 4px; padding: 10px; margin-top: 20px; max-height: 150px; overflow-y: auto; font-size: 12px;">
          <div style="color: #888;">System ready...</div>
        </div>
      </div>

      <p style="text-align: center; color: #888; font-size: 12px; margin-top: 20px;">
        ℹ️ Educational purposes only. This simulates dictionary attack methodology.
      </p>
    </div>
  </div>
</div>

<script>
  let ratingLimitEnabled = true;
  let attemptCount = 0;
  const maxAttempts = 3;
  const selectedUser = '<%= @users.first&.id %>';

  function toggleSecurityPanel() {
    const securitySection = document.getElementById('security-section');
    securitySection.style.display = securitySection.style.display === 'none' ? 'flex' : 'none';
  }

  function toggleRateLimiting() {
    ratingLimitEnabled = !ratingLimitEnabled;
    const toggle = document.getElementById('rate-limit-toggle');
    const status = document.getElementById('rate-limit-status');
    
    if (ratingLimitEnabled) {
      toggle.classList.add('enabled');
      status.textContent = 'ON (3 tries)';
    } else {
      toggle.classList.remove('enabled');
      status.textContent = 'OFF (unlimited)';
    }
    
    attemptCount = 0;
    document.getElementById('attack-log').innerHTML = '<div style="color: #888;">Rate limiting ' + (ratingLimitEnabled ? 'enabled' : 'disabled') + '. System ready...</div>';
  }

  function attackWord(password) {
    const userId = document.getElementById('attack-user').value;
    
    if (!userId) {
      addLog('❌ Select a target user first');
      return;
    }

    if (ratingLimitEnabled && attemptCount >= maxAttempts) {
      addLog('🔒 ACCOUNT LOCKED - Too many attempts');
      return;
    }

    if (!password) {
      addLog('❌ No password provided');
      return;
    }

    attemptCount++;

    fetch('<%= attack_sessions_path %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({
        user_id: userId,
        password: password
      })
    })
    .then(response => response.json())
    .then(data => {
      const resultDiv = document.getElementById('attack-result');
      const user = document.querySelector(`#attack-user option[value="${userId}"]`).textContent;
      
      if (data.success) {
        resultDiv.innerHTML = '<div class="attack-result attack-success">' + data.message + '<br>Target: ' + user + '</div>';
        addLog('✅ SUCCESS: ' + password);
        attemptCount = 0; // Reset on success
      } else {
        resultDiv.innerHTML = '<div class="attack-result attack-failure">' + data.message + '</div>';
        const remaining = ratingLimitEnabled ? maxAttempts - attemptCount : '∞';
        addLog('❌ ' + password + ' (Attempt ' + attemptCount + '/' + (ratingLimitEnabled ? maxAttempts : '∞') + ')');
      }
    })
    .catch(error => {
      addLog('⚠️ Error: ' + error);
    });
  }

  function addLog(message) {
    const log = document.getElementById('attack-log');
    const timestamp = new Date().toLocaleTimeString();
    const entry = document.createElement('div');
    entry.style.color = message.includes('SUCCESS') ? '#00ff00' : (message.includes('LOCKED') ? '#ffaa00' : '#ff4444');
    entry.textContent = '[' + timestamp + '] ' + message;
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
  }
</script>

