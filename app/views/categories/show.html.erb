<div style="max-width: 800px; margin: 40px auto; padding: 30px; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <h2 style="margin-top: 0;"><%= @category.name %></h2>
  <% if current_user.admin? %>
    <p style="margin: -10px 0 20px 0; color: #888; font-size: 14px;">Created by: <strong><%= @category.user.name %></strong></p>
  <% end %>
  <div style="margin-bottom: 30px;">
    <h3>Pending products</h3>
    <% if @category.products.any? %>
      <table style="width: 100%; border-collapse: collapse; background: #fafafa;">
        <thead>
          <tr style="background: #f0f0f0; border-bottom: 1px solid #ddd;">
            <th style="padding: 10px; text-align: left;">Name</th>
            <th style="padding: 10px; text-align: right;">Price</th>
            <th style="padding: 10px; text-align: center;">Quantity</th>
            <th style="padding: 10px; text-align: center;"></th>
          </tr>
        </thead>
        <tbody>
          <% @category.products.where.not(status: 'purchased').each do |product| %>
  <tr style="border-bottom: 1px solid #eee;">
    <td style="padding: 10px;"><%= link_to product.name, product_path(product), style: "color: #0066cc; text-decoration: none;" %></td>
    <td style="padding: 10px; text-align: right;">€ <%= number_with_precision(product.price, precision: 2) %></td>
    <td style="padding: 10px; text-align: center;"><%= product.amount %></td>
    <td style="padding: 10px; text-align: center;">
      <%= button_to "✓ Buy", mark_product_purchased_category_path(@category, product_id: product.id),
          method: :patch,
          style: "background: #28a745; color: white; border: none; padding: 5px 12px; border-radius: 4px; cursor: pointer; font-size: 12px;" %>
      <%= button_to "✕ Remove", remove_product_category_path(@category, product_id: product.id),
      method: :patch,
      data: { confirm: "Remove the product from this category?" },
      style: "background: #dc3545; color: white; border: none; padding: 5px 12px; border-radius: 4px; cursor: pointer; font-size: 12px; margin-left: 6px;" %>
    </td>
  </tr>
<% end %>
        </tbody>
      </table>
<% if @category.products.where.not(status: 'purchased').any? %>
  <div style="text-align: right; margin-top: 8px; margin-bottom: 4px;">
    <%= button_to "✓ Buy all", mark_all_purchased_category_path(@category),
        method: :patch,
        data: { confirm: "Buy all products?" },
        style: "background: #28a745; color: white; border: none; padding: 7px 16px; border-radius: 4px; cursor: pointer;" %>
  </div>
<% end %>
      <p style="text-align: right; margin-top: 8px;">
        <strong>Total sum:</strong>
        <% if @limit > 0 && @total_sum > @limit %>
          <span style="color: #ff0000;">
            € <%= number_with_precision(@total_sum, precision: 2) %>
            (Limit exceeded by € <%= number_with_precision(@total_sum - @limit, precision: 2) %>)
          </span>
        <% else %>
          € <%= number_with_precision(@total_sum, precision: 2) %>
        <% end %>
      </p>
    <% else %>
      <p style="color: #999;">No product in this category.</p>
    <% end %>
  </div>

  <div style="margin-bottom: 30px;">
    <h3>Purchased products</h3>
    <% if @purchased_products.any? %>
      <table style="width: 100%; border-collapse: collapse; background: #fafafa;">
        <thead>
          <tr style="background: #d4edda; border-bottom: 1px solid #ddd;">
            <th style="padding: 10px; text-align: left;">Name</th>
            <th style="padding: 10px; text-align: right;">Price</th>
            <th style="padding: 10px; text-align: center;">Quantity</th>
          </tr>
        </thead>
        <tbody>
          <% @purchased_products.each do |product| %>
            <tr style="border-bottom: 1px solid #eee;">
              <td style="padding: 10px;"><%= link_to product.name, product_path(product), style: "color: #0066cc; text-decoration: none;" %></td>
              <td style="padding: 10px; text-align: right;">€ <%= number_with_precision(product.price, precision: 2) %></td>
              <td style="padding: 10px; text-align: center;"><%= product.amount %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <p style="text-align: right; margin-top: 8px;">
        <strong>Spent:</strong>
        <% if @limit > 0 && @spent_sum > @limit %>
          <span style="color: #ff0000;">
            € <%= number_with_precision(@spent_sum, precision: 2) %>
            (Limit exceeded by € <%= number_with_precision(@spent_sum - @limit, precision: 2) %>)
          </span>
        <% else %>
          € <%= number_with_precision(@spent_sum, precision: 2) %>
        <% end %>
      </p>
    <% else %>
      <p style="color: #999;">No products bought yet.</p>
    <% end %>
  </div>

  <% if @limit > 0 %>
    <div style="background: #f9f9f9; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
      <p style="margin: 0 0 4px 0;"><strong>Limit:</strong> € <%= number_with_precision(@limit, precision: 2) %></p>

      <% total_pct = [(@total_sum / @limit.to_f * 100).round(1), 100].min %>
      <p style="margin: 12px 0 4px 0; font-size: 14px;">
        Total sum (all products): <%= total_pct %>%
        <% if @total_sum > @limit %>
          <span style="color: #ff0000; font-weight: bold;"> – Limit exceeded!</span>
        <% end %>
      </p>
      <div style="background: #e0e0e0; border-radius: 6px; height: 18px; overflow: hidden;">
        <div style="width: <%= total_pct %>%; height: 100%; background: <%= @total_sum > @limit ? '#ff4444' : '#ffa500' %>; border-radius: 6px; transition: width 0.3s;"></div>
      </div>

      <% spent_pct = [(@spent_sum / @limit.to_f * 100).round(1), 100].min %>
      <p style="margin: 12px 0 4px 0; font-size: 14px;">
        Spent (only purchased products): <%= spent_pct %>%
        <% if @spent_sum > @limit %>
          <span style="color: #ff0000; font-weight: bold;"> – Limit exceeded!</span>
        <% end %>
      </p>
      <div style="background: #e0e0e0; border-radius: 6px; height: 18px; overflow: hidden;">
        <div style="width: <%= spent_pct %>%; height: 100%; background: <%= @spent_sum > @limit ? '#ff4444' : '#28a745' %>; border-radius: 6px; transition: width 0.3s;"></div>
      </div>
    </div>
  <% end %>

  <div style="display: flex; gap: 10px;">
    <%= link_to "Edit", edit_category_path(@category), style: "background: #ffa500; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none;" %>
    <%= link_to "Delete", category_path(@category), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, style: "background: #ff0000; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none;" %>
    <%= link_to "Back", categories_path, style: "background: #666; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none;" %>
  </div>
</div>