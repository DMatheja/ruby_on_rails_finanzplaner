<div class="page-header">
  <h2 class="mb-0">Categories</h2>
  <%= link_to "Add New Category", new_category_path, class: "btn btn-primary" %>
</div>

<% if @categories.any? %>
  <div class="grid grid-auto">
    <% @categories.each do |category| %>
      <div class="card card-hover">
        <h3><%= link_to category.name, category_path(category) %></h3>
        <% if current_user.admin? %>
          <p class="text-muted" style="font-size: 12px;">Created by: <strong><%= category.user.name %></strong></p>
        <% end %>

        <% spent = category.spent_amount %>
        <% total = category.total_amount %>
        <% limit = category.limit || 0 %>

        <p class="mb-2"><strong>Limit:</strong> € <%= number_with_precision(limit, precision: 2) %></p>

        <% if limit > 0 %>
          <% total_pct = [(total / limit.to_f * 100).round(1), 100].min %>
          <% total_over = total > limit %>
          <p class="text-muted mb-0" style="font-size: 12px;">
            Total: € <%= number_with_precision(total, precision: 2) %> (<%= total_pct %>%)
            <% if total_over %>
              <span class="text-danger" style="font-weight: 700;">+€ <%= number_with_precision(total - limit, precision: 2) %></span>
            <% end %>
          </p>
          <div class="progress mb-2" style="margin-top: 4px;">
            <div class="progress-bar <%= total_over ? 'progress-bar-danger' : 'progress-bar-warning' %>" style="width: <%= total_pct %>%;"></div>
          </div>

          <% spent_pct = [(spent / limit.to_f * 100).round(1), 100].min %>
          <% spent_over = spent > limit %>
          <p class="text-muted mb-0" style="font-size: 12px;">
            Spent: € <%= number_with_precision(spent, precision: 2) %> (<%= spent_pct %>%)
            <% if spent_over %>
              <span class="text-danger" style="font-weight: 700;">+€ <%= number_with_precision(spent - limit, precision: 2) %></span>
            <% end %>
          </p>
          <div class="progress">
            <div class="progress-bar <%= spent_over ? 'progress-bar-danger' : 'progress-bar-success' %>" style="width: <%= spent_pct %>%;"></div>
          </div>
        <% else %>
          <p class="text-faint" style="font-size: 12px;">No limit set.</p>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="empty-state">No categories yet. <%= link_to "Create one", new_category_path %></p>
<% end %>