<div class="card form-card">
  <h2 class="mt-0">New Product</h2>

  <% if @product.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(@product.errors.count, "error") %> prohibited this product from being saved:</strong>
      <ul style="margin: 8px 0 0; padding-left: 20px;">
        <% @product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with(model: @product, local: true) do |form| %>
    <div class="form-group">
      <%= form.label :category_id, "Category (optional)", class: "form-label" %>
      <%= form.collection_select :category_id, @categories, :id,
          ->(c) { current_user.admin? ? "#{c.name} (#{c.user.name})" : c.name },
          { include_blank: "No category" }, class: "form-select" %>
    </div>

    <div class="form-group">
      <%= form.label :name, "Product Name", class: "form-label" %>
      <%= form.text_field :name, placeholder: "e.g., Milk, Coffee", class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :price, "Price (€)", class: "form-label" %>
      <%= form.number_field :price, step: 0.01, placeholder: "e.g., 2.50", class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :amount, "Quantity", class: "form-label" %>
      <%= form.number_field :amount, min: 1, placeholder: "1", class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :status, class: "form-label" %>
      <%= form.select :status, { "Pending" => "pending", "Purchased" => "purchased" }, {}, class: "form-select" %>
    </div>

    <%= form.submit "Create Product", class: "btn btn-primary btn-block" %>
  <% end %>

  <%= link_to "← Back", products_path, class: "btn btn-ghost btn-sm" %>
</div>
