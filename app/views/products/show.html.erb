<div style="max-width: 600px; margin: 40px auto; padding: 30px; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <h2 style="margin-top: 0;"><%= @product.name %></h2>

  <div style="background: #f9f9f9; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
    <p style="margin: 0 0 10px 0;"><strong>Category:</strong>
      <% if @product.category.present? %>
        <%= link_to @product.category.name, category_path(@product.category), style: "color: #0066cc; text-decoration: none;" %>
      <% else %>
        <span style="color: #999;">No Category </span>
      <% end %>
    </p>
    <p style="margin: 0 0 10px 0;"><strong>Price:</strong> € <%= number_with_precision(@product.price, precision: 2) %></p>
    <p style="margin: 0 0 10px 0;"><strong>Quantity:</strong> <%= @product.amount %></p>
    <p style="margin: 0 0 10px 0;"><strong>Total:</strong> € <%= number_with_precision(@product.price * @product.amount, precision: 2) %></p>
    <p style="margin: 0;">
      <strong>Status:</strong>
      <span style="background: <% if @product.status == 'purchased' %>#d4edda<% else %>#fff3cd<% end %>; padding: 4px 8px; border-radius: 4px;">
        <%= @product.status.titleize %>
      </span>
    </p>
  </div>

  <div style="display: flex; gap: 10px;">
    <%= link_to "Edit", edit_product_path(@product), style: "background: #ffa500; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none;" %>
    <%= link_to "Delete", product_path(@product), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, style: "background: #ff0000; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none;" %>
    <%= link_to "Back", products_path, style: "background: #666; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none;" %>
  </div>
</div>
