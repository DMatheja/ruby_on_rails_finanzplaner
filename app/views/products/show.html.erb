<div class="card form-card">
  <h2 class="mt-0"><%= @product.name %></h2>

  <div class="card card-compact mb-4" style="background: var(--color-bg); box-shadow: none;">
    <% if current_user.admin? %>
      <p><strong>Created by:</strong> <%= @product.owner&.name || "Unbekannt (kein Eigentümer/keine Kategorie)" %></p>
    <% end %>
    <p><strong>Category:</strong>
      <% if @product.category.present? %>
        <%= link_to @product.category.name, category_path(@product.category) %>
      <% else %>
        <span class="text-faint">No Category</span>
      <% end %>
    </p>
    <p><strong>Price:</strong> € <%= number_with_precision(@product.price, precision: 2) %></p>
    <p><strong>Quantity:</strong> <%= @product.amount %></p>
    <p><strong>Total:</strong> € <%= number_with_precision(@product.price * @product.amount, precision: 2) %></p>
    <p class="mb-0">
      <strong>Status:</strong>
      <span class="badge <%= @product.status == 'purchased' ? 'badge-success' : 'badge-warning' %>">
        <%= @product.status.titleize %>
      </span>
    </p>
  </div>

  <div class="flex gap-2">
    <%= link_to "Edit", edit_product_path(@product), class: "btn btn-warning" %>
    <%= link_to "Delete", product_path(@product), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
    <%= link_to "Back", products_path, class: "btn btn-secondary" %>
  </div>
</div>
